// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum EmployerTier {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  APPLICANT
  RECRUITER
  ADMIN
}

enum PipelineStage {
  APPLIED
  SEEN
  SHORTLISTED
  INTERVIEW
  OFFER
  REJECTED
  EXPIRED
}

enum RejectionReason {
  PORTFOLIO_GAP
  SALARY_MISMATCH
  SPECIFIC_SKILL_MISSING
  ROLE_FILLED
  OVERQUALIFIED
}

enum JobType {
  FULL_TIME
  REMOTE
  CONTRACT
  INTERNSHIP
  PART_TIME
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum NotificationType {
  APPLICATION_STATUS_CHANGE
  DIRECT_MESSAGE
  SLA_WARNING
  SLA_BREACH
  REJECTION_REASON
  RECRUITER_APPROVED
  RECRUITER_REJECTED
  SALARY_APPROVED
  SALARY_REJECTED
  JOB_ALERT
  INTERVIEW_SCHEDULED
  INTERVIEW_REMINDER
  REFERRAL_JOINED
  SKILL_VERIFIED
  REVIEW_RECEIVED
  APPLICATION_WITHDRAWN
  JOB_EXPIRING
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  role          Role      @default(APPLICANT)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Applicant fields
  skills              String[]
  experienceLevel     ExperienceLevel?
  location            String?
  openToOpportunities Boolean  @default(false)
  targetRoles         String[]

  // Recruiter fields
  companyName          String?
  businessEmail        String?
  recruiterVerified    Boolean @default(false)
  suspended            Boolean @default(false)
  responseRate         Float   @default(100)
  avgResponseTimeHours Float?

  // Company profile (recruiter)
  companyDescription   String?
  companyWebsite       String?
  companyLogoPublicId  String?
  companySize          String?
  companyIndustry      String?
  companyLocation      String?

  // Skill verification
  verifiedSkills       String[]  @default([])

  // Applicant public profile
  portfolioUrl         String?
  bio                  String?
  avatarPublicId       String?
  profileSlug          String?   @unique

  // 2FA
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?

  // Theme preference
  themePreference      String?   @default("system")

  // Enterprise tier fields
  tier                 EmployerTier @default(FREE)
  maxRecruiterSeats    Int          @default(1)
  subscriptionExpiry   DateTime?
  accountManagerName   String?
  hasCvAccess          Boolean      @default(false)

  jobPosts                  JobPost[]
  applications              Application[]
  notifications             Notification[]
  salaryEntries             SalaryEntry[]
  sentMessages              Message[]       @relation("SentMessages")
  messageThreadsAsApplicant MessageThread[] @relation("ApplicantThreads")
  messageThreadsAsRecruiter MessageThread[] @relation("RecruiterThreads")
  headhuntOutreachSent      HeadhuntOutreach[] @relation("OutreachSent")
  headhuntOutreachReceived  HeadhuntOutreach[] @relation("OutreachReceived")
  savedJobs                 SavedJob[]
  jobAlerts                 JobAlert[]
  interviewsAsApplicant     InterviewSlot[]    @relation("InterviewApplicant")
  interviewsAsRecruiter     InterviewSlot[]    @relation("InterviewRecruiter")
  referralsSent             Referral[]         @relation("ReferralSender")
  referralsReceived         Referral[]         @relation("ReferralReceiver")
  skillVerifications        SkillVerification[]
  reviewsGiven              Review[]           @relation("ReviewGiver")
  reviewsReceived           Review[]           @relation("ReviewReceiver")
}

model JobPost {
  id                    String          @id @default(cuid())
  recruiterId           String
  recruiter             User            @relation(fields: [recruiterId], references: [id])
  title                 String
  description           String
  skills                String[]
  location              String
  city                  String
  salaryMin             Int
  salaryMax             Int
  experienceLevel       ExperienceLevel
  jobType               JobType
  category              String[]
  isActive              Boolean         @default(true)
  isClosed              Boolean         @default(false)
  isInactiveLowResponse Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  requiredFields        String[]        @default(["name", "email"])
  expiresAt            DateTime?
  publicFeedback       String?
  isFeatured           Boolean   @default(false)
  featuredUntil        DateTime?
  applyUrl             String?
  isPremium            Boolean   @default(false)

  applications Application[]
  savedByUsers SavedJob[]

  @@index([city])
  @@index([jobType])
  @@index([experienceLevel])
  @@index([isActive, isClosed])
}

model Application {
  id              String           @id @default(cuid())
  jobPostId       String
  jobPost         JobPost          @relation(fields: [jobPostId], references: [id])
  applicantId     String
  applicant       User             @relation(fields: [applicantId], references: [id])
  stage           PipelineStage    @default(APPLIED)
  rejectionReason RejectionReason?
  recruiterNotes  String?
  applicantName      String?
  applicantEmail     String?
  applicantPhone     String?
  yearsOfExperience  Int?
  coverLetter        String?
  cvPublicId         String?
  cvFileName         String?
  submittedAt     DateTime         @default(now())
  firstSeenAt     DateTime?
  firstActionAt   DateTime?
  slaWarning7Sent  Boolean         @default(false)
  slaWarning13Sent Boolean         @default(false)
  updatedAt       DateTime         @updatedAt
  withdrawnAt          DateTime?
  isWithdrawn          Boolean   @default(false)

  messageThread MessageThread?

  @@unique([jobPostId, applicantId])
}

model MessageThread {
  id                String       @id @default(cuid())
  applicationId     String?      @unique
  application       Application? @relation(fields: [applicationId], references: [id])
  applicantId       String
  applicant         User         @relation("ApplicantThreads", fields: [applicantId], references: [id])
  recruiterId       String
  recruiter         User         @relation("RecruiterThreads", fields: [recruiterId], references: [id])
  isHeadhunt        Boolean      @default(false)
  applicantAccepted Boolean?
  createdAt         DateTime     @default(now())

  messages Message[]
}

model Message {
  id          String        @id @default(cuid())
  threadId    String
  thread      MessageThread @relation(fields: [threadId], references: [id])
  senderId    String
  sender      User          @relation("SentMessages", fields: [senderId], references: [id])
  content     String
  sentAt      DateTime      @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model SalaryEntry {
  id                 String             @id @default(cuid())
  submittedById      String
  submittedBy        User               @relation(fields: [submittedById], references: [id])
  roleTitle          String
  experienceLevel    ExperienceLevel
  city               String
  salaryAmount       Int
  employmentType     JobType
  techStack          String[]
  verificationStatus VerificationStatus @default(UNVERIFIED)
  evidenceUrl        String?
  createdAt          DateTime           @default(now())
  reviewedAt         DateTime?
}

model HeadhuntOutreach {
  id          String   @id @default(cuid())
  recruiterId String
  recruiter   User     @relation("OutreachSent", fields: [recruiterId], references: [id])
  applicantId String
  applicant   User     @relation("OutreachReceived", fields: [applicantId], references: [id])
  sentAt      DateTime @default(now())
  declinedAt  DateTime?

  @@unique([recruiterId, applicantId])
}

model DemandSnapshot {
  id             String   @id @default(cuid())
  skill          String
  category       String?
  city           String?
  count          Int
  classification String   @default("Neutral")
  snapshotDate   DateTime
  timeRange      Int

  @@unique([skill, timeRange, snapshotDate])
  @@index([skill, snapshotDate])
}

// ─── Saved Jobs ───────────────────────────────────────────────────────────────

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostId String
  jobPost   JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@unique([userId, jobPostId])
  @@index([userId])
}

// ─── Job Alerts ───────────────────────────────────────────────────────────────

model JobAlert {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords        String[]
  city            String?
  jobType         JobType?
  experienceLevel ExperienceLevel?
  salaryMin       Int?
  isActive        Boolean         @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime        @default(now())

  @@index([userId])
  @@index([isActive])
}

// ─── Interview Scheduler ──────────────────────────────────────────────────────

enum InterviewStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  COMPLETED
}

model InterviewSlot {
  id            String          @id @default(cuid())
  applicationId String
  recruiterId   String
  recruiter     User            @relation("InterviewRecruiter", fields: [recruiterId], references: [id])
  applicantId   String
  applicant     User            @relation("InterviewApplicant", fields: [applicantId], references: [id])
  proposedSlots DateTime[]
  confirmedSlot DateTime?
  status        InterviewStatus @default(PENDING)
  meetingLink   String?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([applicationId])
  @@index([applicantId])
  @@index([recruiterId])
}

// ─── Referral System ─────────────────────────────────────────────────────────

model Referral {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("ReferralSender", fields: [senderId], references: [id])
  receiverId  String?
  receiver    User?     @relation("ReferralReceiver", fields: [receiverId], references: [id])
  jobPostId   String
  code        String    @unique
  clicks      Int       @default(0)
  conversions Int       @default(0)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  @@index([senderId])
  @@index([code])
}

// ─── Skill Verification ───────────────────────────────────────────────────────

enum VerificationMethod {
  QUIZ
  PORTFOLIO
  ENDORSEMENT
}

model SkillVerification {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill       String
  method      VerificationMethod
  score       Int?
  evidenceUrl String?
  verifiedAt  DateTime           @default(now())
  expiresAt   DateTime?

  @@unique([userId, skill])
  @@index([userId])
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

enum ReviewType {
  APPLICANT_REVIEWS_RECRUITER
  RECRUITER_REVIEWS_APPLICANT
}

model Review {
  id            String     @id @default(cuid())
  giverId       String
  giver         User       @relation("ReviewGiver", fields: [giverId], references: [id])
  receiverId    String
  receiver      User       @relation("ReviewReceiver", fields: [receiverId], references: [id])
  type          ReviewType
  rating        Int
  comment       String?
  applicationId String?
  createdAt     DateTime   @default(now())

  @@unique([giverId, receiverId, applicationId])
  @@index([receiverId])
}
